        "import torch.nn as nn\n",
        "from torch.utils.data import DataLoader\n",
        "from transformers import BertTokenizer\n",
        "import pandas as pd\n",
        "from utils import get_splits, get_device\n",
        "from models.fusion_pipeline.train import MultimodalDataset, evaluate\n",
        "device = get_device()\n",
        "tok    = BertTokenizer.from_pretrained('bert-base-uncased')\n",
        "import pandas as pd\n",
        "df_cached = pd.read_csv('/content/emotion_project/prosody_descriptions.csv')\n",
        "_, _, te  = get_splits(df_cached)\n",
        "tel       = DataLoader(MultimodalDataset(te, tok), batch_size=16, shuffle=False, num_workers=2)\n",
        "fusion_model.to(device).eval()\n",
        "_, _, fusion_pred, fusion_true = evaluate(fusion_model, tel, nn.CrossEntropyLoss(), device)\n",
        "from sklearn.metrics import accuracy_score, classification_report\n",
        "emotion_labels = ['angry','disgust','fear','happy','neutral','ps','sad']\n",
        "print(f'Fusion Test Accuracy: {accuracy_score(fusion_true, fusion_pred)*100:.2f}%')\n",
        "print(classification_report(fusion_true, fusion_pred, target_names=emotion_labels))\n"
      ]
    },
